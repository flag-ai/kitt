# KITT 2.0 environment configuration.
# Copy this file to .env and fill in real values before running docker
# compose. The server refuses to start when KITT_ADMIN_TOKEN is empty.

# ==== Core (required) =========================================================
DATABASE_URL=postgres://kitt:kitt@localhost:5432/kitt?sslmode=disable
KITT_ADMIN_TOKEN=replace-me-with-a-32-byte-random-string

# ==== Core (optional) =========================================================
LISTEN_ADDR=:8080
LOG_LEVEL=info
LOG_FORMAT=text
KITT_CORS_ORIGINS=http://localhost:5173

# ==== Devon bridge (optional) =================================================
KITT_DEVON_URL=
KITT_DEVON_TOKEN=

# ==== Notifications (optional) ================================================
KITT_SLACK_WEBHOOK=
KITT_DISCORD_WEBHOOK=

# ==== docker compose ==========================================================
POSTGRES_DB=kitt
POSTGRES_USER=kitt
POSTGRES_PASSWORD=kitt
